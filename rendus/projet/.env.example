# Copier vers .env et remplir (ne jamais committer .env)
# cp .env.example .env

# --- Docker Hub (push image + workflow projet-cd.yml) ---
DOCKERHUB_USERNAME=romainmlt
DOCKERHUB_TOKEN=
DOCKER_IMAGE=romainmlt/devops-cv-webapp:latest

# --- Render (déploiement CD optionnel) ---
# Créer un Web Service sur https://render.com (rootDir: rendus/projet/webapp)
RENDER_SERVICE_ID=
RENDER_API_KEY=
RENDER_URL=https://devops-cv-webapp.onrender.com

# --- GitHub (pour gh secret set — à configurer dans Settings → Secrets) ---
# Les mêmes noms sont utilisés côté Actions :
# DOCKERHUB_USERNAME, DOCKERHUB_TOKEN, RENDER_SERVICE_ID, RENDER_API_KEY

# --- Enseignant (invitation manuelle sur github.com) ---
# GITHUB_TEACHER_USERNAME=adaltas

# --- Redis local (tests / make start) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
